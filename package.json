{
  "name": "@wzelong/llm-chat-ui",
  "version": "0.1.0",
  "description": "Portable LLM chat UI — plug in any model, get streaming chat with reasoning steps",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters/sse": {
      "types": "./dist/adapters/sse.d.ts",
      "import": "./dist/adapters/sse.js",
      "require": "./dist/adapters/sse.cjs"
    },
    "./adapters/openai": {
      "types": "./dist/adapters/openai.d.ts",
      "import": "./dist/adapters/openai.js",
      "require": "./dist/adapters/openai.cjs"
    },
    "./adapters/anthropic": {
      "types": "./dist/adapters/anthropic.d.ts",
      "import": "./dist/adapters/anthropic.js",
      "require": "./dist/adapters/anthropic.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./parser": {
      "types": "./dist/parser.d.ts",
      "import": "./dist/parser.js",
      "require": "./dist/parser.cjs"
    }
  },
  "bin": {
    "llm-chat-ui": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "cli/templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "vue": ">=3.3",
    "zustand": ">=4"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "zustand": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "dependencies": {
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19",
    "react": "^19",
    "tsup": "^8",
    "typescript": "^5",
    "vue": "^3.5.31",
    "zustand": "^5"
  },
  "keywords": [
    "llm",
    "chat",
    "streaming",
    "sse",
    "react",
    "openai",
    "anthropic",
    "ui"
  ],
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Wzelong/llm-chat-ui.git"
  }
}
